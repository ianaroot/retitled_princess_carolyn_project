<div data-controller="sidebar"
     data-sidebar-target="sidebar">
  
  <button data-action="click->sidebar#toggle"
          class="hamburger"
          aria-label="Toggle navigation">
    <span class="hamburger__line"></span>
    <span class="hamburger__line"></span>
    <span class="hamburger__line"></span>
  </button>
  
  <div class="sidebar__content">
    <div class="sidebar__logo">
      <div class="pixel-robot"></div>
      <span class="sidebar__title">Pawnstorm</span>
    </div>
    
    <nav class="sidebar__nav">
      <%= link_to "Home", root_path,
          class: "sidebar__link #{'sidebar__link--active' if current_page?(root_path)}",
          data: { action: "click->sidebar#navigate" } %>
      
      <%= link_to "Play Game", new_game_path,
          class: "sidebar__link #{'sidebar__link--active' if current_page?(new_game_path)}",
          data: { action: "click->sidebar#navigate" } %>
      
      <%= link_to "Bots", bots_path,
          class: "sidebar__link #{'sidebar__link--active' if controller_name == 'bots'}",
          data: { action: "click->sidebar#navigate" } %>
    </nav>
    
    <div class="sidebar__auth">
      <% if user_signed_in? %>
        <div class="sidebar__user">
          <%= current_user.email %>
        </div>
        <%= button_to "Sign Out", destroy_user_session_path,
            method: :delete,
            class: "sidebar__link sidebar__link--signout",
            data: { action: "click->sidebar#navigate" } %>
      <% else %>
        <%= link_to "Sign In", new_user_session_path,
            class: "sidebar__link",
            data: { action: "click->sidebar#navigate" } %>
        <%= link_to "Sign Up", new_user_registration_path,
            class: "sidebar__link sidebar__link--primary",
            data: { action: "click->sidebar#navigate" } %>
      <% end %>
    </div>
  </div>
</div>

<div data-sidebar-target="overlay"
     class="sidebar-overlay"
     data-action="click->sidebar#close"></div>