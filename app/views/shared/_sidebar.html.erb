<div data-controller="sidebar"
     data-sidebar-target="sidebar">
  
  <button data-action="click->sidebar#toggle"
          class="hamburger"
          aria-label="Toggle navigation">
    <span class="hamburger__line"></span>
    <span class="hamburger__line"></span>
    <span class="hamburger__line"></span>
  </button>
  
  <div class="sidebar__content">
    <div class="sidebar__logo">
<svg class="sidebar__logo-icon" viewBox="0 -8 48 78" width="48" height="78" aria-hidden="true">
        <!-- Pawn base (wide, flat bottom) -->
        <rect x="4" y="60" width="40" height="8" rx="2" fill="#9CA3AF"/>
        <rect x="8" y="64" width="32" height="4" rx="1" fill="#6B7280"/>
        
        <!-- Pawn body (longer, tapers from collar to base) -->
        <path d="M16 36 L12 60 L36 60 L32 36 Z" fill="#9CA3AF"/>
        
        <!-- Collar ring (wider, below narrow neck) -->
        <ellipse cx="24" cy="34" rx="14" ry="4" fill="#6B7280"/>
        <ellipse cx="24" cy="34" rx="10" ry="2.5" fill="#4B5563"/>
        
        <!-- Narrow neck (short, thin section below head) -->
        <rect x="20" y="28" width="8" height="4" fill="#9CA3AF"/>
        
        <!-- Pawn head (wider round bulb) -->
        <ellipse cx="24" cy="16" rx="13" ry="14" fill="#9CA3AF"/>
        
        <!-- Robot face plate -->
        <rect x="12" y="8" width="24" height="14" rx="3" fill="#374151"/>
        
        <!-- Left eye -->
        <circle cx="18" cy="15" r="3" fill="#A855F7"/>
        <circle cx="18" cy="15" r="1.5" fill="#E5E5E5"/>
        
        <!-- Right eye -->
        <circle cx="30" cy="15" r="3" fill="#A855F7"/>
        <circle cx="30" cy="15" r="1.5" fill="#E5E5E5"/>
        
        <!-- Antenna (off-center right) -->
        <line x1="28" y1="4" x2="28" y2="-4" stroke="#9CA3AF" stroke-width="2"/>
        <circle cx="28" cy="-4" r="2" fill="#A855F7"/>
        
        <!-- Chest panel lines (spread along longer body) -->
        <line x1="18" y1="42" x2="30" y2="42" stroke="#6B7280" stroke-width="1"/>
        <line x1="16" y1="49" x2="32" y2="49" stroke="#6B7280" stroke-width="1"/>
        <line x1="14" y1="56" x2="34" y2="56" stroke="#6B7280" stroke-width="1"/>
      </svg>
      <span class="sidebar__title">Pawnstorm</span>
    </div>
    
    <nav class="sidebar__nav">
      <%= link_to "Home", root_path,
          class: "sidebar__link #{'sidebar__link--active' if current_page?(root_path)}",
          data: { action: "click->sidebar#navigate" } %>
      
      <%= link_to "Play Game", new_game_path,
          class: "sidebar__link #{'sidebar__link--active' if current_page?(new_game_path)}",
          data: { action: "click->sidebar#navigate" } %>
      
      <%= link_to "Bots", bots_path,
          class: "sidebar__link #{'sidebar__link--active' if controller_name == 'bots'}",
          data: { action: "click->sidebar#navigate" } %>
    </nav>
    
    <div class="sidebar__auth">
      <% if user_signed_in? %>
        <div class="sidebar__user">
          <%= current_user.email %>
        </div>
        <%= button_to "Sign Out", destroy_user_session_path,
            method: :delete,
            class: "sidebar__link sidebar__link--signout",
            data: { action: "click->sidebar#navigate" } %>
      <% else %>
        <%= link_to "Sign In", new_user_session_path,
            class: "sidebar__link",
            data: { action: "click->sidebar#navigate" } %>
        <%= link_to "Sign Up", new_user_registration_path,
            class: "sidebar__link sidebar__link--primary",
            data: { action: "click->sidebar#navigate" } %>
      <% end %>
    </div>
  </div>
</div>

<div data-sidebar-target="overlay"
     class="sidebar-overlay"
     data-action="click->sidebar#close"></div>