<div id="node-editor-panel" class="node-editor-panel hidden">
  <h3>Edit Node</h3>
  <div class="panel-content">
    <div class="form-group">
      <label>Type</label>
      <span id="edit-node-type"></span>
    </div>
    
    <div id="condition-editor" class="node-editor-section hidden">
      <h4>Condition</h4>
      
      <div class="editor-part">
        <label>1. Context</label>
        <select id="cond-context">
          <option value="self">Self</option>
          <option value="allies">Allies</option>
          <option value="enemies">Enemies</option>
          <option value="any">Any</option>
        </select>
        
        <div class="piece-filter">
          <label>Piece Type Filter</label>
          <select id="cond-piece-filter-type">
            <option value="specific">Specific piece</option>
            <option value="negative">Is NOT</option>
            <option value="value">Piece value</option>
          </select>
          
          <div id="cond-piece-specific" class="piece-filter-option">
            <select id="cond-piece-type">
              <option value="any">Any</option>
              <option value="pawn">Pawn</option>
              <option value="knight">Knight</option>
              <option value="bishop">Bishop</option>
              <option value="rook">Rook</option>
              <option value="queen">Queen</option>
              <option value="king">King</option>
            </select>
          </div>
          
          <div id="cond-piece-negative" class="piece-filter-option hidden">
            <select id="cond-piece-negative-type">
              <option value="pawn">Pawn</option>
              <option value="knight">Knight</option>
              <option value="bishop">Bishop</option>
              <option value="rook">Rook</option>
              <option value="queen">Queen</option>
              <option value="king">King</option>
            </select>
          </div>
          
          <div id="cond-piece-value" class="piece-filter-option hidden">
            <select id="cond-piece-value-op">
              <option value=">">&gt;</option>
              <option value="==">==</option>
              <option value="<">&lt;</option>
              <option value=">=">&gt;=</option>
              <option value="<=">&lt;=</option>
            </select>
            <input type="number" id="cond-piece-value-num" min="1" max="9" value="3">
          </div>
        </div>
      </div>
      
      <div class="editor-part">
        <label>2. Query</label>
        <select id="cond-query">
          <option value="is_attacked">Is attacked</option>
          <option value="is_attacking">Is attacking</option>
          <option value="is_skewered">Is skewered</option>
          <option value="is_pinning">Is pinning</option>
          <option value="Has moved yethas_moved"></option>
          <option value="just_moved">Did just move</option>
          <option value="position">Position</option>
        </select>
      </div>
      
      <div id="cond-details" class="editor-part hidden">
        <label>3. Details</label>
        
        <div id="cond-details-attacked" class="cond-detail-section hidden">
          <label>Attacker details</label>
          <select id="cond-attacker-filter-type">
            <option value="any">Any</option>
            <option value="specific">Specific piece</option>
            <option value="value">By value</option>
          </select>
          <div id="cond-attacker-specific" class="hidden">
            <select id="cond-attacker-type">
              <option value="pawn">Pawn</option>
              <option value="knight">Knight</option>
              <option value="bishop">Bishop</option>
              <option value="rook">Rook</option>
              <option value="queen">Queen</option>
              <option value="king">King</option>
            </select>
          </div>
          <div id="cond-attacker-value" class="hidden">
            <select id="cond-attacker-value-op">
              <option value=">">&gt;</option>
              <option value="==">==</option>
              <option value="<">&lt;</option>
            </select>
            <input type="number" id="cond-attacker-value-num" min="1" max="9" value="3">
          </div>
        </div>
        
        <div id="cond-details-attacking" class="cond-detail-section hidden">
          <label>Attacked piece details</label>
          <select id="cond-attacked-filter-type">
            <option value="any">Any</option>
            <option value="specific">Specific piece</option>
            <option value="value">By value</option>
          </select>
          <div id="cond-attacked-specific" class="hidden">
            <select id="cond-attacked-type">
              <option value="pawn">Pawn</option>
              <option value="knight">Knight</option>
              <option value="bishop">Bishop</option>
              <option value="rook">Rook</option>
              <option value="queen">Queen</option>
              <option value="king">King</option>
            </select>
          </div>
          <div id="cond-attacked-value" class="hidden">
            <select id="cond-attacked-value-op">
              <option value=">">&gt;</option>
              <option value="==">==</option>
              <option value="<">&lt;</option>
            </select>
            <input type="number" id="cond-attacked-value-num" min="1" max="9" value="3">
          </div>
        </div>
        
        <div id="cond-details-position" class="cond-detail-section hidden">
          <label>Position</label>
          <select id="cond-position-type">
            <option value="rank">Rank</option>
            <option value="file">File</option>
          </select>
          <select id="cond-position-op">
            <option value=">">&gt;</option>
            <option value="==">==</option>
            <option value="<">&lt;</option>
            <option value=">=">&gt;=</option>
            <option value="<=">&lt;=</option>
          </select>
          <input type="number" id="cond-position-num" min="1" max="8" value="4">
          <select id="cond-position-file" class="hidden">
            <option value="a">a</option>
            <option value="b">b</option>
            <option value="c">c</option>
            <option value="d">d</option>
            <option value="e">e</option>
            <option value="f">f</option>
            <option value="g">g</option>
            <option value="h">h</option>
          </select>
        </div>
      </div>
    </div>
    
    <div id="action-editor" class="node-editor-section hidden">
      <h4>Action</h4>
      <div id="action-fields"></div>
    </div>
  </div>
  <div class="panel-actions">
    <button id="save-node" class="btn-save">Save</button>
    <button id="cancel-edit" class="btn-cancel">Cancel</button>
  </div>
</div>
