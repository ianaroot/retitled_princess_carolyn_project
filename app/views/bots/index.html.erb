<h1>My Bots</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Description</th>
      <th>Created</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @bots.each do |bot| %>
      <tr>
        <td><%= bot.name %></td>
        <td><%= bot.description %></td>
        <td><%= bot.created_at.strftime("%Y-%m-%d") %></td>
        <td>
          <%= link_to 'Edit', edit_bot_path(bot) %>
          <%= link_to 'Delete', bot, method: :delete, data: { confirm: 'Are you sure?' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to 'New Bot', new_bot_path %>
