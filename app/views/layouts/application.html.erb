<!DOCTYPE html>
<html>
  <head>
    <title>RetitledPrincessCarolynProject</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%# Always include CSRF token for JavaScript API calls even when forgery protection is disabled %>
    <% if protect_against_forgery? == false && respond_to?(:form_authenticity_token) %>
      <meta name="csrf-param" content="authenticity_token">
      <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <% end %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-environment="<%= Rails.env %>">
    <p class="notice"><%= notice %></p> 
    <p class="alert"><%= alert %></p> 
    <%= yield %>
  </body>
</html>
